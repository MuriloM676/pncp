# API Compras.gov.br (Dados Abertos)
PNCP_BASE_URL=https://dadosabertos.compras.gov.br

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Cache TTLs (em segundos)
CACHE_TTL_OPORTUNIDADES=300
CACHE_TTL_PROCESSO=600

# Rate Limit
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW=60

# App
APP_ENV=development
CORS_ALLOWED_ORIGINS=http://localhost
