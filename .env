# API PNCP (Usando Treinamento devido a instabilidade na Produção)
PNCP_BASE_URL=https://treina.pncp.gov.br/api/consulta/v1

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Cache TTLs (em segundos)
CACHE_TTL_OPORTUNIDADES=300
CACHE_TTL_DISPUTA=15
CACHE_TTL_PROCESSO=600
CACHE_TTL_FORNECEDOR=1800
CACHE_TTL_STATUS=60
CACHE_TTL_CHAT=30

# Rate Limit
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW=60

# App
APP_ENV=development
CORS_ALLOWED_ORIGINS=http://localhost
