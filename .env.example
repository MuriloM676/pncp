# API PNCP / Portal de Compras Públicas
PNCP_BASE_URL=https://apipcp.portaldecompraspublicas.com.br/publico
# OBRIGATÓRIO: Solicite sua chave em https://portaldecompraspublicas.zendesk.com/
PNCP_PUBLIC_KEY=SUA_CHAVE_AQUI

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Cache TTLs (em segundos)
CACHE_TTL_OPORTUNIDADES=300
CACHE_TTL_DISPUTA=15
CACHE_TTL_PROCESSO=600
CACHE_TTL_FORNECEDOR=1800
CACHE_TTL_STATUS=60
CACHE_TTL_CHAT=30

# Rate Limit
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW=60

# App
APP_ENV=development
CORS_ALLOWED_ORIGINS=http://localhost
